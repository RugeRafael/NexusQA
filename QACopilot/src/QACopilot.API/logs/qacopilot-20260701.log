SELECT [p].[Id], [p].[AssignedAt], [p].[AssignedByUserId], [p].[IsActive], [p].[Notes], [p].[ProjectId], [p].[UserId], [p0].[Id], [p0].[CreatedAt], [p0].[CreatedByUserId], [p0].[Description], [p0].[EndDate], [p0].[Name], [p0].[StartDate], [p0].[Status], [u].[Id], [u].[CreatedAt], [u].[Email], [u].[FullName], [u].[IsActive], [u].[LastLoginAt], [u].[PasswordHash], [u].[Role], [p1].[Id], [p1].[AssignedAt], [p1].[AssignedByUserId], [p1].[IsActive], [p1].[Notes], [p1].[ProjectId], [p1].[UserId]
